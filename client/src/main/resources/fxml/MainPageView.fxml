<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<BorderPane xmlns="http://javafx.com/javafx/17.0.12"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.auction.client.controller.MainPageController"
            prefWidth="900.0"
            prefHeight="600.0"
            style="-fx-background-color: #f3f4f6;">

    <!-- 🔷 TOP BAR -->
    <top>
        <HBox alignment="CENTER_RIGHT"
              spacing="15"
              style="-fx-background-color: white; -fx-padding: 15; -fx-border-color: #e5e7eb;">
            
            <children>

                <!-- Username -->
                <Label text="Welcome,"
                       style="-fx-text-fill: #6b7280;"/>
                
                <Label fx:id="usernameLabel"
                       text="User"
                       style="-fx-text-fill: #111827;">
                    <font>
                        <Font name="System Bold" size="13"/>
                    </font>
                </Label>

                <!-- Logout Button -->
                <Button text="Log Out"
                        onAction="#switchToLogin"
                        prefWidth="90"
                        prefHeight="30"
                        style="-fx-background-color: transparent; -fx-border-color: #ef4444; -fx-text-fill: #ef4444; -fx-background-radius: 6; -fx-border-radius: 6; -fx-cursor: hand;">
                </Button>

            </children>
        </HBox>
    </top>

    <!-- 🔷 LEFT SIDEBAR -->
    <left>
        <VBox spacing="15"
              prefWidth="200"
              style="-fx-background-color: white; -fx-padding: 20; -fx-border-color: #e5e7eb;">
            
            <children>

                <Label text="Menu">
                    <font>
                        <Font name="System Bold" size="18"/>
                    </font>
                </Label>

                <Button text="Create Auction"
                        onAction="#switchToCreateAuction"
                        prefWidth="160"
                        prefHeight="40"
                        style="-fx-background-color: #4f46e5; -fx-text-fill: white; -fx-background-radius: 8; -fx-cursor: hand;"/>

            </children>
        </VBox>
    </left>

    <!-- 🔷 CENTER CONTENT -->
    <center>
        <VBox alignment="CENTER"
              spacing="10">
            
            <children>
                <Label text="Main Page">
                    <font>
                        <Font size="24"/>
                    </font>
                </Label>

                <Label text="Welcome to the Auction System"
                       style="-fx-text-fill: #6b7280;"/>
            </children>

        </VBox>
    </center>

</BorderPane>