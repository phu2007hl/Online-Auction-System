<?xml version="1.0" encoding="UTF-8"?>

<?import java.lang.*?>
<?import javafx.collections.*?>
<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>

<BorderPane prefHeight="700.0" prefWidth="950.0" style="-fx-background-color: #f3f4f6;" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.auction.client.controller.auction.CreateAuctionPageController">

    <center>
        <!-- Tăng maxHeight để chứa thêm các trường mới -->
        <VBox alignment="TOP_CENTER" maxHeight="620" maxWidth="700" spacing="15" style="-fx-background-color: white; -fx-padding: 30; -fx-background-radius: 12; -fx-border-color: #e5e7eb; -fx-border-radius: 12;">

            <Label style="-fx-text-fill: #111827;" text="Tạo phiên đấu giá mới">
                <font>
                    <Font name="System Bold" size="24" />
                </font>
            </Label>

            <Label style="-fx-text-fill: #6b7280;" text="Vui lòng điền đầy đủ thông tin sản phẩm bên dưới">
                <VBox.margin>
                    <Insets bottom="5" top="-10" />
                </VBox.margin>
            </Label>

            <GridPane alignment="CENTER" hgap="20" vgap="12">

                <!-- 1. TÊN SẢN PHẨM -->
                <Label style="-fx-text-fill: #374151; -fx-font-weight: bold;" text="Tên sản phẩm:" GridPane.columnIndex="0" GridPane.rowIndex="0" />
                <TextField fx:id="productNameField" prefWidth="380" promptText="Nhập tên sản phẩm (VD: iPhone 15 Pro Max...)" style="-fx-background-color: #f9fafb; -fx-border-color: #d1d5db; -fx-border-radius: 6; -fx-background-radius: 6; -fx-padding: 8;" GridPane.columnIndex="1" GridPane.rowIndex="0" />

                <!-- 2. LOẠI SẢN PHẨM -->
                <Label style="-fx-text-fill: #374151; -fx-font-weight: bold;" text="Loại sản phẩm:" GridPane.columnIndex="0" GridPane.rowIndex="1" />
                <ComboBox fx:id="categoryComboBox" prefWidth="380" promptText="-- Chọn danh mục --" style="-fx-background-color: #f9fafb; -fx-border-color: #d1d5db; -fx-border-radius: 6; -fx-background-radius: 6;" GridPane.columnIndex="1" GridPane.rowIndex="1">
                    <items>
                        <FXCollections fx:factory="observableArrayList">
                            <String fx:value="Electronic" />
                            <String fx:value="Art" />
                            <String fx:value="Vehicle" />
                            <String fx:value="Fashion" />
                        </FXCollections>
                    </items>
                </ComboBox>

                <!-- 3. GIÁ KHỞI ĐIỂM -->
                <Label style="-fx-text-fill: #374151; -fx-font-weight: bold;" text="Giá khởi điểm ($):" GridPane.columnIndex="0" GridPane.rowIndex="2" />
                <TextField fx:id="startingPriceField" prefWidth="380" promptText="VD: 150.00" style="-fx-background-color: #f9fafb; -fx-border-color: #d1d5db; -fx-border-radius: 6; -fx-background-radius: 6; -fx-padding: 8;" GridPane.columnIndex="1" GridPane.rowIndex="2" />

                <!-- 4. BƯỚC GIÁ TỐI THIỂU (MỚI THÊM) -->
                <Label style="-fx-text-fill: #374151; -fx-font-weight: bold;" text="Bước giá tối thiểu ($):" GridPane.columnIndex="0" GridPane.rowIndex="3" />
                <TextField fx:id="minimumIncrementField" prefWidth="380" promptText="VD: 10.00 (Số tiền tối thiểu mỗi lần trả giá)" style="-fx-background-color: #f9fafb; -fx-border-color: #d1d5db; -fx-border-radius: 6; -fx-background-radius: 6; -fx-padding: 8;" GridPane.columnIndex="1" GridPane.rowIndex="3" />

                <!-- 5. NGÀY KẾT THÚC -->
                <Label style="-fx-text-fill: #374151; -fx-font-weight: bold;" text="Ngày kết thúc:" GridPane.columnIndex="0" GridPane.rowIndex="4" />
                <DatePicker fx:id="endDatePicker" prefWidth="380" promptText="Chọn ngày..." style="-fx-background-color: #f9fafb; -fx-border-color: #d1d5db; -fx-border-radius: 6; -fx-background-radius: 6;" GridPane.columnIndex="1" GridPane.rowIndex="4" />

                <!-- 6. HÌNH ẢNH -->
                <Label style="-fx-text-fill: #374151; -fx-font-weight: bold;" text="Hình ảnh:" GridPane.columnIndex="0" GridPane.rowIndex="5" />
                <HBox alignment="CENTER_LEFT" spacing="10" GridPane.columnIndex="1" GridPane.rowIndex="5">
                    <Button onAction="#handleUploadImage" style="-fx-background-color: #e5e7eb; -fx-text-fill: #374151; -fx-background-radius: 6; -fx-cursor: hand; -fx-padding: 5 15;" text="Chọn tệp" />
                    <Label fx:id="imagePathLabel" style="-fx-text-fill: #9ca3af; -fx-font-style: italic;" text="Chưa có ảnh nào được chọn" />
                </HBox>

                <!-- 7. MÔ TẢ CHI TIẾT -->
                <Label style="-fx-text-fill: #374151; -fx-font-weight: bold;" text="Mô tả chi tiết:" GridPane.columnIndex="0" GridPane.rowIndex="6" GridPane.valignment="TOP">
                    <GridPane.margin>
                        <Insets top="8" />
                    </GridPane.margin>
                </Label>
                <TextArea fx:id="descriptionArea" prefHeight="80" prefWidth="380" promptText="Viết mô tả chi tiết về tình trạng, xuất xứ của sản phẩm..." style="-fx-background-color: #f9fafb; -fx-border-color: #d1d5db; -fx-border-radius: 6; -fx-background-radius: 6;" wrapText="true" GridPane.columnIndex="1" GridPane.rowIndex="6" />
                
                <columnConstraints>
                    <ColumnConstraints hgrow="SOMETIMES" minWidth="150.0" />
                    <ColumnConstraints hgrow="SOMETIMES" minWidth="380.0" />
                </columnConstraints>
                <rowConstraints>
                    <RowConstraints minHeight="10.0" vgrow="SOMETIMES" />
                    <RowConstraints minHeight="10.0" vgrow="SOMETIMES" />
                    <RowConstraints minHeight="10.0" vgrow="SOMETIMES" />
                    <RowConstraints minHeight="10.0" vgrow="SOMETIMES" />
                    <RowConstraints minHeight="10.0" vgrow="SOMETIMES" />
                    <RowConstraints minHeight="10.0" vgrow="SOMETIMES" />
                    <RowConstraints minHeight="10.0" vgrow="SOMETIMES" />
                </rowConstraints>
            </GridPane>

            <Label fx:id="messageLabel" style="-fx-text-fill: #16a34a; -fx-font-weight: bold;" text="" />

            <HBox alignment="CENTER" spacing="15">
                <Button onAction="#switchToMain" prefHeight="38" prefWidth="130" style="-fx-background-color: transparent; -fx-border-color: #9ca3af; -fx-text-fill: #4b5563; -fx-border-radius: 8; -fx-cursor: hand;" text="Quay lại">
                    <font>
                        <Font name="System Bold" size="14" />
                    </font>
                </Button>
                <Button defaultButton="true" onAction="#handleCreateAuction" prefHeight="38" prefWidth="130" style="-fx-background-color: #4f46e5; -fx-text-fill: white; -fx-background-radius: 8; -fx-cursor: hand;" text="Tạo đấu giá">
                    <font>
                        <Font name="System Bold" size="14" />
                    </font>
                </Button>
            </HBox>

        </VBox>
    </center>

</BorderPane>
