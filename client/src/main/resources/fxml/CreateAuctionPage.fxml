<?xml version="1.0" encoding="UTF-8"?>

<?import java.lang.*?>
<?import javafx.collections.*?>
<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>

<BorderPane prefHeight="600.0" prefWidth="900.0" style="-fx-background-color: #f3f4f6;" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.auction.client.controller.CreateAuctionPageController">

    <center>
        <VBox alignment="TOP_CENTER" maxHeight="520" maxWidth="650" spacing="20" style="-fx-background-color: white; -fx-padding: 30; -fx-background-radius: 12; -fx-border-color: #e5e7eb; -fx-border-radius: 12;">

            <Label style="-fx-text-fill: #111827;" text="Tạo Phiên Đấu Giá Mới">
                <font>
                    <Font name="System Bold" size="24" />
                </font>
            </Label>

            <Label style="-fx-text-fill: #6b7280;" text="Vui lòng điền đầy đủ thông tin sản phẩm bên dưới">
                <VBox.margin>
                    <Insets bottom="10" top="-15" />
                </VBox.margin>
            </Label>

            <GridPane alignment="CENTER" hgap="20" vgap="15">

                <Label style="-fx-text-fill: #374151; -fx-font-weight: bold;" text="Tên sản phẩm:" GridPane.columnIndex="0" GridPane.rowIndex="0" />
                <TextField fx:id="productNameField" prefWidth="350" promptText="Nhập tên sản phẩm..." style="-fx-background-color: #f9fafb; -fx-border-color: #d1d5db; -fx-border-radius: 6; -fx-background-radius: 6; -fx-padding: 8;" GridPane.columnIndex="1" GridPane.rowIndex="0" />

                <Label style="-fx-text-fill: #374151; -fx-font-weight: bold;" text="Loại sản phẩm:" GridPane.columnIndex="0" GridPane.rowIndex="1" />
                <ComboBox fx:id="categoryComboBox" prefWidth="350" promptText="-- Chọn danh mục --" style="-fx-background-color: #f9fafb; -fx-border-color: #d1d5db; -fx-border-radius: 6; -fx-background-radius: 6;" GridPane.columnIndex="1" GridPane.rowIndex="1">
                    <items>
                        <FXCollections fx:factory="observableArrayList">
                            <String fx:value="Electronic" />
                            <String fx:value="Art" />
                            <String fx:value="Vehicle" />
                        </FXCollections>
                    </items>
                </ComboBox>

                <Label style="-fx-text-fill: #374151; -fx-font-weight: bold;" text="Giá khởi điểm ($):" GridPane.columnIndex="0" GridPane.rowIndex="2" />
                <TextField fx:id="startingPriceField" prefWidth="350" promptText="VD: 150.00" style="-fx-background-color: #f9fafb; -fx-border-color: #d1d5db; -fx-border-radius: 6; -fx-background-radius: 6; -fx-padding: 8;" GridPane.columnIndex="1" GridPane.rowIndex="2" />

                <Label style="-fx-text-fill: #374151; -fx-font-weight: bold;" text="Ngày kết thúc:" GridPane.columnIndex="0" GridPane.rowIndex="3" />
                <DatePicker fx:id="endDatePicker" prefWidth="350" promptText="Chọn ngày..." style="-fx-background-color: #f9fafb; -fx-border-color: #d1d5db; -fx-border-radius: 6; -fx-background-radius: 6;" GridPane.columnIndex="1" GridPane.rowIndex="3" />

                <Label style="-fx-text-fill: #374151; -fx-font-weight: bold;" text="Hình ảnh:" GridPane.columnIndex="0" GridPane.rowIndex="4" />
                <HBox alignment="CENTER_LEFT" spacing="10" GridPane.columnIndex="1" GridPane.rowIndex="4">
                    <Button onAction="#handleUploadImage" style="-fx-background-color: #e5e7eb; -fx-text-fill: #374151; -fx-background-radius: 6; -fx-cursor: hand; -fx-padding: 5 15;" text="Chọn file" />
                    <Label fx:id="imagePathLabel" style="-fx-text-fill: #9ca3af; -fx-font-style: italic;" text="Chưa có ảnh nào được chọn" />
                </HBox>

                <Label style="-fx-text-fill: #374151; -fx-font-weight: bold;" text="Mô tả chi tiết:" GridPane.columnIndex="0" GridPane.rowIndex="5" GridPane.valignment="TOP">
                    <GridPane.margin>
                        <Insets top="8" />
                    </GridPane.margin>
                </Label>
                <TextArea fx:id="descriptionArea" prefHeight="90" prefWidth="350" promptText="Viết mô tả chi tiết về tình trạng, xuất xứ của sản phẩm..." style="-fx-background-color: #f9fafb; -fx-border-color: #d1d5db; -fx-border-radius: 6; -fx-background-radius: 6;" wrapText="true" GridPane.columnIndex="1" GridPane.rowIndex="5" />
            <columnConstraints>
               <ColumnConstraints />
               <ColumnConstraints />
            </columnConstraints>
            <rowConstraints>
               <RowConstraints />
               <RowConstraints />
               <RowConstraints />
               <RowConstraints />
               <RowConstraints />
               <RowConstraints />
            </rowConstraints>
            </GridPane>

            <HBox alignment="CENTER" spacing="15">
                <VBox.margin>
                    <Insets top="15" />
                </VBox.margin>
                <Button onAction="#switchToMain" prefHeight="38" prefWidth="130" style="-fx-background-color: transparent; -fx-border-color: #9ca3af; -fx-text-fill: #4b5563; -fx-border-radius: 8; -fx-cursor: hand;" text="Quay Lại">
                    <font>
                        <Font name="System Bold" size="14" />
                    </font>
                </Button>
                <Button defaultButton="true" onAction="#handleCreateAuction" prefHeight="38" prefWidth="130" style="-fx-background-color: #4f46e5; -fx-text-fill: white; -fx-background-radius: 8; -fx-cursor: hand;" text="Tạo Đấu Giá">
                    <font>
                        <Font name="System Bold" size="14" />
                    </font>
                </Button>
            </HBox>

        </VBox>
    </center>

</BorderPane>
