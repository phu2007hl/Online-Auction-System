<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.canvas.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>

<VBox alignment="CENTER" prefHeight="600.0" prefWidth="400.0" spacing="15.0" style="-fx-background-color: #f4f4f4;" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.auction.client.controller.LoginController">
    <children>
        <VBox alignment="CENTER" maxWidth="320.0" spacing="12.0" style="-fx-background-color: white; -fx-border-color: #c9a66b; -fx-border-width: 5; -fx-padding: 30;">
            <children>
                <Label text="Hệ thống Đấu giá">
                    <font>
                        <Font name="System Bold" size="24.0" />
                    </font>
                    <VBox.margin>
                        <Insets bottom="10.0" />
                    </VBox.margin>
                </Label>

                <VBox alignment="CENTER_LEFT" spacing="5.0">
                    <children>
                        <Label text="Tên đăng nhập:" />
                        <TextField fx:id="tfUsername" promptText="Nhập username..." style="-fx-background-radius: 30;" />
                    </children>
                </VBox>

                <VBox alignment="CENTER_LEFT" spacing="5.0" style="-fx-background-radius: 30;">
                    <children>
                        <Label text="Mật khẩu:" />
                        <PasswordField fx:id="pfPassword" promptText="Nhập password..." style="-fx-background-radius: 30;" />
                    </children>
                </VBox>

                <Label fx:id="lblStatus" textAlignment="CENTER" wrapText="true">
                    <font>
                        <Font size="13.0" />
                    </font>
                </Label>

                <VBox alignment="CENTER" spacing="8.0">
                    <children>
                        <Canvas fx:id="captchaCanvas" height="50.0" onMouseClicked="#reloadCaptcha" width="150.0" />
                        <TextField fx:id="tfCaptcha" maxWidth="150.0" promptText="Nhập mã xác nhận" />
                    </children>
                </VBox>

                <Button defaultButton="true" maxWidth="Infinity" mnemonicParsing="false" onAction="#handleLogin" prefHeight="35.0" text="Đăng nhập">
                    <font>
                        <Font name="System Bold" size="14.0" />
                    </font>
                </Button>

                <Label text="Chưa có tài khoản">
                    <VBox.margin>
                        <Insets top="10.0" />
                    </VBox.margin>
                </Label>

                <Button maxWidth="Infinity" mnemonicParsing="false" onAction="#handleGoToRegister" prefHeight="35.0" text="Đăng ký" />
            </children>
        </VBox>
    </children>
    <padding>
        <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
    </padding>
</VBox>
