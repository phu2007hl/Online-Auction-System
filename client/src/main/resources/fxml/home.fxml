<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<BorderPane prefHeight="700.0" prefWidth="1000.0" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.auction.client.controller.HomeController">

    <top>
        <HBox alignment="CENTER_RIGHT" prefHeight="70.0" spacing="20.0" style="-fx-background-color: #2c3e50; -fx-padding: 0 30 0 30;" BorderPane.alignment="CENTER">
            <children>
                <Label text="HỆ THỐNG ĐẤU GIÁ" textFill="WHITE" HBox.hgrow="ALWAYS">
                    <font>
                        <Font name="System Bold" size="22.0" />
                    </font>
                </Label>
                <HBox alignment="CENTER_RIGHT" spacing="15.0" HBox.hgrow="ALWAYS">
                    <children>
                        <Label fx:id="lblUsername" text="Xin chào, Phú!" textFill="WHITE">
                            <font>
                                <Font size="16.0" />
                            </font>
                        </Label>
                        <Button mnemonicParsing="false" onAction="#handleViewProfile" style="-fx-background-color: #34495e; -fx-text-fill: white;" text="Profile" />
                        <Button mnemonicParsing="false" onAction="#handleLogout" style="-fx-background-color: #e74c3c; -fx-text-fill: white;" text="Đăng xuất" />
                    </children>
                </HBox>
            </children>
        </HBox>
    </top>

    <left>
        <VBox prefWidth="220.0" spacing="10.0" style="-fx-background-color: #34495e; -fx-padding: 20;" BorderPane.alignment="CENTER">
            <children>
                <Label text="MENU CHÍNH" textFill="#bdc3c7">
                    <font>
                        <Font name="System Bold" size="13.0" />
                    </font>
                </Label>
                <Button maxWidth="Infinity" mnemonicParsing="false" onAction="#showAuctionList" prefHeight="40.0" style="-fx-background-color: transparent; -fx-text-fill: white; -fx-alignment: CENTER_LEFT;" text="🛒 Tham gia đấu giá" />
                <Button maxWidth="Infinity" mnemonicParsing="false" onAction="#showCategories" prefHeight="40.0" style="-fx-background-color: transparent; -fx-text-fill: white; -fx-alignment: CENTER_LEFT;" text="📂 Danh mục sản phẩm" />
                <Button maxWidth="Infinity" mnemonicParsing="false" onAction="#showSellProduct" prefHeight="40.0" style="-fx-background-color: transparent; -fx-text-fill: white; -fx-alignment: CENTER_LEFT;" text="💰 Mục bán (Sellers)" />
                <Separator prefWidth="200.0" />
            </children>
        </VBox>
    </left>

    <center>
        <StackPane fx:id="contentArea" style="-fx-background-color: #ecf0f1;" BorderPane.alignment="CENTER">
            <children>
                <Label text="Chào mừng bạn đến với hệ thống đấu giá trực tuyến!">
                    <font>
                        <Font size="18.0" />
                    </font>
                </Label>
            </children>
        </StackPane>
    </center>
</BorderPane>