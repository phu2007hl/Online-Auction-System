<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<AnchorPane prefHeight="700.0" prefWidth="950.0" style="-fx-background-color: #f3f4f6;"
            xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.auction.client.controller.admin.CheckedAuctionHistoryController">
  <children>
    <VBox spacing="18.0" AnchorPane.bottomAnchor="24.0" AnchorPane.leftAnchor="24.0"
          AnchorPane.rightAnchor="24.0" AnchorPane.topAnchor="24.0">
      <children>
        <HBox alignment="CENTER_LEFT" spacing="12.0">
          <children>
            <Button onAction="#switchToAdminDashboard" text="Quay lại duyệt auction"
                    style="-fx-cursor: hand;" />
            <Label style="-fx-font-size: 24px; -fx-font-weight: bold;" text="Lịch sử duyệt auction" />
          </children>
        </HBox>
        <TableView fx:id="historyTable" VBox.vgrow="ALWAYS">
          <columns>
            <TableColumn fx:id="idColumn" prefWidth="70.0" text="ID" />
            <TableColumn fx:id="pictureColumn" prefWidth="180.0" text="Ảnh" />
            <TableColumn fx:id="nameColumn" prefWidth="190.0" text="Tên sản phẩm" />
            <TableColumn fx:id="categoryColumn" prefWidth="140.0" text="Danh mục" />
            <TableColumn fx:id="ownerColumn" prefWidth="160.0" text="User tạo" />
            <TableColumn fx:id="priceColumn" prefWidth="150.0" text="Giá khởi điểm" />
            <TableColumn fx:id="statusColumn" prefWidth="130.0" text="Trạng thái" />
          </columns>
        </TableView>
      </children>
    </VBox>
  </children>
</AnchorPane>
