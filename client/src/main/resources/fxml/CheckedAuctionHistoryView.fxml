<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.auction.client.controller.admin.CheckedAuctionHistoryController"
            prefWidth="1100"
            prefHeight="650"
            style="-fx-background-color: #f3f4f6;">

  <top>
    <HBox alignment="CENTER_RIGHT"
          spacing="15"
          style="-fx-background-color: white; -fx-padding: 15 20; -fx-border-color: #e5e7eb;">
      <children>
        <Button onAction="#switchToAdminDashboard"
                text="Quay lại"
                prefWidth="95"
                prefHeight="32"
                style="-fx-background-color: transparent; -fx-border-color: #4f46e5; -fx-text-fill: #4f46e5; -fx-background-radius: 8; -fx-border-radius: 8; -fx-cursor: hand;"/>
        <Region HBox.hgrow="ALWAYS"/>
        <Label text="Lịch sử duyệt auction"
               style="-fx-font-size: 24px; -fx-font-weight: bold; -fx-text-fill: #111827;"/>
        <Region HBox.hgrow="ALWAYS"/>
        <Region prefWidth="95"/>
      </children>
    </HBox>
  </top>

  <center>
    <VBox spacing="15" style="-fx-padding: 20;">
      <children>
        <VBox spacing="4">
          <children>
            <Label text="Auction đã xử lý"
                   style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: #111827;"/>
            <Label text="Theo dõi các yêu cầu đã được admin chấp nhận hoặc từ chối"
                   style="-fx-text-fill: #6b7280;"/>
          </children>
        </VBox>

        <TableView fx:id="historyTable"
                   VBox.vgrow="ALWAYS"
                   style="-fx-background-color: white; -fx-border-color: #e5e7eb; -fx-border-radius: 12; -fx-background-radius: 12;">
          <columns>
            <TableColumn fx:id="idColumn" prefWidth="80.0" text="ID" />
            <TableColumn fx:id="pictureColumn" prefWidth="170.0" text="Ảnh" />
            <TableColumn fx:id="nameColumn" prefWidth="210.0" text="Tên sản phẩm" />
            <TableColumn fx:id="categoryColumn" prefWidth="140.0" text="Danh mục" />
            <TableColumn fx:id="ownerColumn" prefWidth="150.0" text="User tạo" />
            <TableColumn fx:id="priceColumn" prefWidth="150.0" text="Giá khởi điểm" />
            <TableColumn fx:id="statusColumn" prefWidth="150.0" text="Trạng thái" />
          </columns>
        </TableView>
      </children>
    </VBox>
  </center>
</BorderPane>
