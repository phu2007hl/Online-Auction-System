<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<BorderPane xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.auction.client.controller.auction.MyAuctionHistoryController"
            prefWidth="1100.0"
            prefHeight="720.0"
            style="-fx-background-color: #f3f4f6;">

    <top>
        <HBox alignment="CENTER_RIGHT"
              spacing="15"
              style="-fx-background-color: white; -fx-padding: 15; -fx-border-color: #e5e7eb;">
            <children>
                <Label text="Xin chào,"
                       style="-fx-text-fill: #6b7280;" />

                <Label fx:id="usernameLabel"
                       text="Người dùng"
                       style="-fx-text-fill: #111827;">
                    <font>
                        <Font name="System Bold" size="13" />
                    </font>
                </Label>
            </children>
        </HBox>
    </top>

    <left>
        <VBox spacing="15"
              prefWidth="200"
              style="-fx-background-color: white; -fx-padding: 20; -fx-border-color: #e5e7eb;">
            <children>
                <Label text="Menu">
                    <font>
                        <Font name="System Bold" size="18" />
                    </font>
                </Label>

                <Button text="Quay lại"
                        onAction="#switchToMainPage"
                        prefWidth="160"
                        prefHeight="40"
                        style="-fx-background-color: transparent; -fx-border-color: #4f46e5; -fx-text-fill: #4f46e5; -fx-background-radius: 8; -fx-border-radius: 8; -fx-cursor: hand;" />
            </children>
        </VBox>
    </left>

    <center>
        <VBox spacing="15"
              alignment="TOP_CENTER"
              style="-fx-padding: 20;">
            <children>
                <Label text="Lịch sử auction">
                    <font>
                        <Font size="24" />
                    </font>
                </Label>

                <Label text="Danh sách các auction của bạn đã được admin chấp nhận hoặc từ chối"
                       style="-fx-text-fill: #6b7280;" />

                <HBox alignment="CENTER_RIGHT"
                      maxWidth="Infinity"
                      style="-fx-padding: 0 10 0 10;">
                    <children>
                        <Button text="Refresh"
                                onAction="#refreshHistory"
                                prefWidth="110"
                                prefHeight="34"
                                style="-fx-background-color: transparent; -fx-border-color: #4f46e5; -fx-text-fill: #4f46e5; -fx-background-radius: 8; -fx-border-radius: 8; -fx-cursor: hand;" />
                    </children>
                </HBox>

                <ScrollPane fitToWidth="true"
                            prefHeight="500"
                            style="-fx-background: transparent; -fx-background-color: transparent;"
                            VBox.vgrow="ALWAYS">
                    <content>
                        <VBox fx:id="historyContainer"
                              spacing="12"
                              fillWidth="true"
                              style="-fx-padding: 10;" />
                    </content>
                </ScrollPane>
            </children>
        </VBox>
    </center>
</BorderPane>
