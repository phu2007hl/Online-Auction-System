<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<BorderPane xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.auction.client.controller.admin.AdminDashboardController"
            prefWidth="1100"
            prefHeight="650"
            style="-fx-background-color: #f3f4f6;">

    <top>
        <HBox alignment="CENTER_RIGHT"
              spacing="15"
              style="-fx-background-color: white; -fx-padding: 15 20; -fx-border-color: #e5e7eb;">
            <children>
                <Region HBox.hgrow="ALWAYS"/>
                <Label text="Bảng điều khiển admin"
                       style="-fx-font-size: 24px; -fx-font-weight: bold; -fx-text-fill: #111827;"/>
                <Region HBox.hgrow="ALWAYS"/>
                <Button onAction="#switchToCheckedAuctionHistory" text="Lịch sử"
                        prefWidth="95"
                        prefHeight="32"
                        style="-fx-background-color: transparent; -fx-border-color: #4f46e5; -fx-text-fill: #4f46e5; -fx-background-radius: 8; -fx-border-radius: 8; -fx-cursor: hand;"/>
            </children>
        </HBox>
    </top>

    <center>
        <VBox spacing="15" style="-fx-padding: 20;">
            <children>
                <HBox alignment="CENTER_LEFT" spacing="10">
                    <children>
                        <VBox spacing="4">
                            <children>
                                <Label text="Yêu cầu chờ duyệt"
                                       style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: #111827;"/>
                                <Label text="Kiểm tra thông tin sản phẩm trước khi chấp nhận hoặc từ chối"
                                       style="-fx-text-fill: #6b7280;"/>
                            </children>
                        </VBox>
                    </children>
                </HBox>
                <TableView fx:id="requestTable"
                           prefWidth="1060"
                           VBox.vgrow="ALWAYS"
                           style="-fx-background-color: white; -fx-border-color: #e5e7eb; -fx-border-radius: 12; -fx-background-radius: 12;">
                    <columns>
                        <TableColumn fx:id="idColumn"
                                     text="ID"
                                     prefWidth="70"/>

                        <TableColumn fx:id="pictureColumn"
                                     text="Hình ảnh"
                                     prefWidth="180"/>

                        <TableColumn fx:id="nameColumn"
                                     text="Tên sản phẩm"
                                     prefWidth="140"/>

                        <TableColumn fx:id="categoryColumn"
                                     text="Danh mục"
                                     prefWidth="110"/>

                        <TableColumn fx:id="ownerColumn"
                                     text="User tạo"
                                     prefWidth="130"/>

                        <TableColumn fx:id="priceColumn"
                                     text="Giá khởi điểm"
                                     prefWidth="120"/>

                        <TableColumn fx:id="actionColumn"
                                     text="Thao tác"
                                     prefWidth="130"/>
                    </columns>
                </TableView>
            </children>
        </VBox>
    </center>
</BorderPane>
