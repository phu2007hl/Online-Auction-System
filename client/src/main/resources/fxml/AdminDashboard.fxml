<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<BorderPane xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.auction.client.controller.admin.AdminDashboardController"
            prefWidth="1100"
            prefHeight="650">

    <top>
        <HBox alignment="CENTER" spacing="16">
            <BorderPane.margin>
                <Insets top="20" bottom="20"/>
            </BorderPane.margin>
            <children>
                <Label text="Bảng điều khiển admin"
                       style="-fx-font-size: 26px; -fx-font-weight: bold;"/>
                <Button onAction="#switchToCheckedAuctionHistory" text="Lịch sử"/>
            </children>
        </HBox>
    </top>

    <center>
        <TableView fx:id="requestTable" prefWidth="1060">
            <BorderPane.margin>
                <Insets left="20" right="20" bottom="20"/>
            </BorderPane.margin>
            <columns>
                <TableColumn fx:id="idColumn"
                             text="ID"
                             prefWidth="70"/>

                <TableColumn fx:id="pictureColumn"
                             text="Hình ảnh"
                             prefWidth="180"/>

                <TableColumn fx:id="nameColumn"
                             text="Tên sản phẩm"
                             prefWidth="140"/>

                <TableColumn fx:id="categoryColumn"
                             text="Danh mục"
                             prefWidth="110"/>

                <TableColumn fx:id="ownerColumn"
                             text="User tạo"
                             prefWidth="130"/>

                <TableColumn fx:id="priceColumn"
                             text="Giá khởi điểm"
                             prefWidth="120"/>

                <TableColumn fx:id="actionColumn"
                             text="Thao tác"
                             prefWidth="160"/>
            </columns>
        </TableView>
    </center>
</BorderPane>
