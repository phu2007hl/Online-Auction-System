<?xml version="1.0" encoding="UTF-8"?>

<?import java.lang.*?>
<?import javafx.collections.*?>
<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.image.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>

<BorderPane prefHeight="700.0"
            prefWidth="950.0"
            style="-fx-background-color: #f3f4f6;"
            xmlns="http://javafx.com/javafx/17.0.12"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.auction.client.controller.admin.SecondEditAuctionController">

    <center>
        <VBox alignment="TOP_CENTER"
              maxHeight="660"
              maxWidth="760"
              spacing="15"
              style="-fx-background-color: white; -fx-padding: 30; -fx-background-radius: 12; -fx-border-color: #e5e7eb; -fx-border-radius: 12;">

            <Label style="-fx-text-fill: #111827;" text="Chỉnh sửa yêu cầu đấu giá">
                <font>
                    <Font name="System Bold" size="24" />
                </font>
            </Label>

            <Label style="-fx-text-fill: #6b7280;" text="Admin chỉ sửa được thông tin mô tả sản phẩm, các trường hệ thống đang bị khóa" />

            <GridPane alignment="CENTER" hgap="20" vgap="12">
                <Label style="-fx-text-fill: #374151; -fx-font-weight: bold;" text="ID request:" GridPane.columnIndex="0" GridPane.rowIndex="0" />
                <TextField fx:id="requestIdField" disable="true" opacity="0.65" prefWidth="380" style="-fx-background-color: #f3f4f6; -fx-border-color: #d1d5db; -fx-border-radius: 6; -fx-background-radius: 6; -fx-padding: 8;" GridPane.columnIndex="1" GridPane.rowIndex="0" />

                <Label style="-fx-text-fill: #374151; -fx-font-weight: bold;" text="User tạo:" GridPane.columnIndex="0" GridPane.rowIndex="1" />
                <TextField fx:id="ownerField" disable="true" opacity="0.65" prefWidth="380" style="-fx-background-color: #f3f4f6; -fx-border-color: #d1d5db; -fx-border-radius: 6; -fx-background-radius: 6; -fx-padding: 8;" GridPane.columnIndex="1" GridPane.rowIndex="1" />

                <Label style="-fx-text-fill: #374151; -fx-font-weight: bold;" text="Tên sản phẩm:" GridPane.columnIndex="0" GridPane.rowIndex="2" />
                <TextField fx:id="productNameField" prefWidth="380" promptText="Nhập tên sản phẩm" style="-fx-background-color: #f9fafb; -fx-border-color: #d1d5db; -fx-border-radius: 6; -fx-background-radius: 6; -fx-padding: 8;" GridPane.columnIndex="1" GridPane.rowIndex="2" />

                <Label style="-fx-text-fill: #374151; -fx-font-weight: bold;" text="Loại sản phẩm:" GridPane.columnIndex="0" GridPane.rowIndex="3" />
                <ComboBox fx:id="categoryComboBox" prefWidth="380" promptText="-- Chọn danh mục --" style="-fx-background-color: #f9fafb; -fx-border-color: #d1d5db; -fx-border-radius: 6; -fx-background-radius: 6;" GridPane.columnIndex="1" GridPane.rowIndex="3">
                    <items>
                        <FXCollections fx:factory="observableArrayList">
                            <String fx:value="Electronic" />
                            <String fx:value="Art" />
                            <String fx:value="Vehicle" />
                            <String fx:value="Fashion" />
                        </FXCollections>
                    </items>
                </ComboBox>

                <Label style="-fx-text-fill: #374151; -fx-font-weight: bold;" text="Giá khởi điểm ($):" GridPane.columnIndex="0" GridPane.rowIndex="4" />
                <TextField fx:id="startingPriceField" disable="true" opacity="0.65" prefWidth="380" style="-fx-background-color: #f3f4f6; -fx-border-color: #d1d5db; -fx-border-radius: 6; -fx-background-radius: 6; -fx-padding: 8;" GridPane.columnIndex="1" GridPane.rowIndex="4" />

                <Label style="-fx-text-fill: #374151; -fx-font-weight: bold;" text="Bước giá tối thiểu ($):" GridPane.columnIndex="0" GridPane.rowIndex="5" />
                <TextField fx:id="minimumIncrementField" disable="true" opacity="0.65" prefWidth="380" style="-fx-background-color: #f3f4f6; -fx-border-color: #d1d5db; -fx-border-radius: 6; -fx-background-radius: 6; -fx-padding: 8;" GridPane.columnIndex="1" GridPane.rowIndex="5" />

                <Label style="-fx-text-fill: #374151; -fx-font-weight: bold;" text="Ngày kết thúc:" GridPane.columnIndex="0" GridPane.rowIndex="6" />
                <DatePicker fx:id="endDatePicker" disable="true" opacity="0.65" prefWidth="380" style="-fx-background-color: #f3f4f6; -fx-border-color: #d1d5db; -fx-border-radius: 6; -fx-background-radius: 6;" GridPane.columnIndex="1" GridPane.rowIndex="6" />

                <Label style="-fx-text-fill: #374151; -fx-font-weight: bold;" text="Hình ảnh:" GridPane.columnIndex="0" GridPane.rowIndex="7" />
                <HBox alignment="CENTER_LEFT" spacing="10" GridPane.columnIndex="1" GridPane.rowIndex="7">
                    <Button onAction="#handleUploadImage" style="-fx-background-color: #e5e7eb; -fx-text-fill: #374151; -fx-background-radius: 6; -fx-cursor: hand; -fx-padding: 5 15;" text="Chọn tệp" />
                    <Label fx:id="imagePathLabel" style="-fx-text-fill: #6b7280; -fx-font-style: italic;" text="Giữ ảnh hiện tại" />
                    <ImageView fx:id="previewImageView" fitHeight="64" fitWidth="64" preserveRatio="true" />
                </HBox>

                <Label style="-fx-text-fill: #374151; -fx-font-weight: bold;" text="Mô tả chi tiết:" GridPane.columnIndex="0" GridPane.rowIndex="8" GridPane.valignment="TOP" />
                <TextArea fx:id="descriptionArea" prefHeight="85" prefWidth="380" promptText="Viết mô tả chi tiết về sản phẩm" style="-fx-background-color: #f9fafb; -fx-border-color: #d1d5db; -fx-border-radius: 6; -fx-background-radius: 6;" wrapText="true" GridPane.columnIndex="1" GridPane.rowIndex="8" />

                <columnConstraints>
                    <ColumnConstraints hgrow="SOMETIMES" minWidth="170.0" />
                    <ColumnConstraints hgrow="SOMETIMES" minWidth="380.0" />
                </columnConstraints>
            </GridPane>

            <Label fx:id="messageLabel" style="-fx-text-fill: #16a34a; -fx-font-weight: bold;" text="" />

            <HBox alignment="CENTER" spacing="15">
                <Button onAction="#switchToEditApprovedAuction" prefHeight="38" prefWidth="130" style="-fx-background-color: transparent; -fx-border-color: #9ca3af; -fx-text-fill: #4b5563; -fx-border-radius: 8; -fx-cursor: hand;" text="Quay lại">
                    <font>
                        <Font name="System Bold" size="14" />
                    </font>
                </Button>
                <Button defaultButton="true" onAction="#handleSaveEdit" prefHeight="38" prefWidth="130" style="-fx-background-color: #eab308; -fx-text-fill: white; -fx-background-radius: 8; -fx-cursor: hand;" text="Lưu chỉnh sửa">
                    <font>
                        <Font name="System Bold" size="14" />
                    </font>
                </Button>
            </HBox>
        </VBox>
    </center>
</BorderPane>
